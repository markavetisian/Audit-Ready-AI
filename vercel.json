{
  "rewrites": [
    { "source": "/api/github-oauth",     "destination": "/api/auth" },
    { "source": "/api/github-callback",  "destination": "/api/auth" },
    { "source": "/api/google-oauth",        "destination": "/api/auth" },
    { "source": "/api/google-callback",     "destination": "/api/auth" },
    { "source": "/api/microsoft-oauth",     "destination": "/api/auth" },
    { "source": "/api/microsoft-callback",  "destination": "/api/auth" },
    { "source": "/api/stripe-cancel",    "destination": "/api/billing" },
    { "source": "/api/stripe-checkout",  "destination": "/api/billing" },
    { "source": "/api/track",            "destination": "/api/telemetry" },
    { "source": "/api/log",              "destination": "/api/telemetry" },
    { "source": "/api/analytics",        "destination": "/api/telemetry" },
    { "source": "/((?!api/).*)", "destination": "/public/index.html" }
  ]
}
